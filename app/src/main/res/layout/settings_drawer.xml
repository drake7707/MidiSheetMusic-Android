<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:elevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Drawer header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:text="@string/settings"
            android:textColor="@color/icons"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="16dp" />

        <!-- Scroll Vertically -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_scroll_vert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scroll_vertically"
            android:padding="12dp" />

        <!-- Use Note Colors -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_use_colors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/use_note_colors"
            android:padding="12dp" />

        <!-- Color Accidentals -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_color_accidentals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/use_accidental_colors"
            android:padding="12dp" />

        <!-- Loop header row: switch + expand arrow, tap arrow area to expand/collapse sub-items -->
        <LinearLayout
            android:id="@+id/layout_loop_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_loop_enable"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/play_measures_in_loop"
                android:padding="12dp" />

            <TextView
                android:id="@+id/txt_loop_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="&#9654;"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Loop sub-items (hidden by default) -->
        <LinearLayout
            android:id="@+id/layout_loop_subitems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:visibility="gone">

            <!-- Loop Start -->
            <LinearLayout
                android:id="@+id/layout_loop_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/play_measures_in_loop_start" />

                <TextView
                    android:id="@+id/txt_loop_start_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:textColor="@color/icons"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="1" />

            </LinearLayout>

            <!-- Loop End -->
            <LinearLayout
                android:id="@+id/layout_loop_end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/play_measures_in_loop_end" />

                <TextView
                    android:id="@+id/txt_loop_end_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:textColor="@color/icons"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="1" />

            </LinearLayout>

        </LinearLayout>

        <!-- Show Measure Numbers -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_show_measures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/show_measures"
            android:padding="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@color/divider" />

        <!-- More Settings -->
        <Button
            android:id="@+id/btn_song_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="@string/song_settings_str" />

        <!-- Save As Images -->
        <Button
            android:id="@+id/btn_save_images"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="@string/save_images_str" />

    </LinearLayout>

</ScrollView>
